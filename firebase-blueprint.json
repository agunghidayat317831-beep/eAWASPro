{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "pengawas", "ppk", "kepala_dinas", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Government project details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contractNumber": { "type": "string", "description": "Nomor Kontrak Proyek" },
        "contractDate": { "type": "string", "format": "date", "description": "Tanggal Kontrak" },
        "spmkDate": { "type": "string", "format": "date", "description": "Tanggal SPMK" },
        "executionPeriod": { "type": "number", "description": "Masa Pelaksanaan Pekerjaan (hari)" },
        "ptCv": { "type": "string" },
        "anggaran": { "type": "number" },
        "progress": { "type": "number" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "location", "ptCv", "anggaran", "progress", "lat", "lng"]
    },
    "Photo": {
      "title": "Photo",
      "description": "Project documentation photo",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string", "enum": ["0%", "50%", "100%"] },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "progress": { "type": "number" }
      },
      "required": ["projectId", "url", "category", "date", "progress"]
    },
    "WeeklyReport": {
      "title": "Weekly Report",
      "description": "Weekly progress report for a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "weekNumber": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "weeklyProgress": { "type": "number", "description": "Progress made in this specific week" },
        "cumulativeProgress": { "type": "number", "description": "Total progress up to this week" },
        "notes": { "type": "string" }
      },
      "required": ["projectId", "weekNumber", "startDate", "endDate", "weeklyProgress", "cumulativeProgress"]
    },
    "Evaluation": {
      "title": "Project Evaluation",
      "description": "Provider evaluation for a specific project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "providerId": { "type": "string" },
        "quality": { "type": "number" },
        "cost": { "type": "number" },
        "time": { "type": "number" },
        "service": { "type": "number" },
        "totalScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "projectName", "providerId", "quality", "cost", "time", "service", "totalScore"]
    },
    "Provider": {
      "title": "Provider",
      "description": "Company/Provider details",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Nama CV/PT" },
        "address": { "type": "string", "description": "Alamat" },
        "npwp": { "type": "string", "description": "NPWP" },
        "email": { "type": "string", "format": "email", "description": "Email" },
        "phone": { "type": "string", "description": "Nomor Telepon" },
        "evaluation": {
          "type": "object",
          "properties": {
            "quality": { "type": "number" },
            "cost": { "type": "number" },
            "time": { "type": "number" },
            "service": { "type": "number" },
            "totalScore": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "address", "npwp", "email", "phone"]
    },
    "AHSP": {
      "title": "Analisa Harga Satuan Pekerjaan",
      "description": "Analysis of unit price of work including labor, materials, and equipment",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "jobName": { "type": "string" },
        "labor": { "type": "array" },
        "materials": { "type": "array" },
        "equipment": { "type": "array" },
        "laborTotal": { "type": "number" },
        "materialsTotal": { "type": "number" },
        "equipmentTotal": { "type": "number" },
        "subtotal": { "type": "number" },
        "overheadPercentage": { "type": "number" },
        "overheadValue": { "type": "number" },
        "totalPrice": { "type": "number" },
        "roundedPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "jobName", "laborTotal", "materialsTotal", "equipmentTotal", "subtotal", "totalPrice", "roundedPrice"]
    },
    "LaborMaster": {
      "title": "Labor Master Data",
      "description": "Master list of labor descriptions, codes, units, and base prices",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "code": { "type": "string" },
        "unit": { "type": "string" },
        "unitPrice": { "type": "number" }
      },
      "required": ["description", "code", "unit", "unitPrice"]
    },
    "MaterialMaster": {
      "title": "Material Master Data",
      "description": "Master list of material descriptions, codes, units, and base prices",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "code": { "type": "string" },
        "unit": { "type": "string" },
        "unitPrice": { "type": "number" }
      },
      "required": ["description", "code", "unit", "unitPrice"]
    },
    "EquipmentMaster": {
      "title": "Equipment Master Data",
      "description": "Master list of equipment descriptions, codes, units, and base prices",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "code": { "type": "string" },
        "unit": { "type": "string" },
        "unitPrice": { "type": "number" }
      },
      "required": ["description", "code", "unit", "unitPrice"]
    },
    "RABItem": {
      "title": "Rencana Anggaran Biaya Item",
      "description": "Individual line item in the Estimated Budget Plan",
      "type": "object",
      "properties": {
        "ahspId": { "type": "string", "description": "Reference to AHSP" },
        "description": { "type": "string" },
        "volume": { "type": "number" },
        "unit": { "type": "string" },
        "unitPrice": { "type": "number" },
        "totalPrice": { "type": "number" }
      },
      "required": ["ahspId", "description", "volume", "unit", "unitPrice", "totalPrice"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project data"
    },
    "/projects/{projectId}/rab/{rabId}": {
      "schema": "RABItem",
      "description": "RAB items for a specific project"
    },
    "/projects/{projectId}/photos/{photoId}": {
      "schema": "Photo",
      "description": "Project documentation photos"
    },
    "/projects/{projectId}/weekly_reports/{reportId}": {
      "schema": "WeeklyReport",
      "description": "Weekly progress reports"
    },
    "/providers/{providerId}": {
      "schema": "Provider",
      "description": "Provider data"
    },
    "/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Project-based provider evaluations"
    },
    "/ahsps/{ahspId}": {
      "schema": "AHSP",
      "description": "Analisa Harga Satuan Pekerjaan data"
    },
    "/labor_masters/{laborId}": {
      "schema": "LaborMaster",
      "description": "Master data for labor components"
    },
    "/material_masters/{materialId}": {
      "schema": "MaterialMaster",
      "description": "Master data for material components"
    },
    "/equipment_masters/{equipmentId}": {
      "schema": "EquipmentMaster",
      "description": "Master data for equipment components"
    }
  }
}
